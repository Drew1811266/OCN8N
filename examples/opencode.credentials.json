{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-n8n-builder"],
  "n8n": {
    "baseUrl": "https://your-instance.app.n8n.cloud/api/v1",
    "apiKey": "${N8N_API_KEY}",
    "mcpUrl": "https://your-instance.app.n8n.cloud/mcp-server/http",
    "credentialEnv": {
      "slackApi": {
        "name": "OpenCode Slack",
        "type": "slackApi",
        "authMode": "api_key",
        "env": {
          "accessToken": "SLACK_BOT_TOKEN"
        },
        "docs": ["Slack bot token with chat:write scope"]
      },
      "gmailOAuth2": {
        "name": "OpenCode Gmail",
        "type": "gmailOAuth2",
        "authMode": "oauth2",
        "env": {},
        "docs": ["Complete OAuth consent in n8n UI before activation."]
      }
    }
  }
}
