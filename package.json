{
  "name": "opencode-n8n-builder",
  "version": "2.0.0",
  "description": "OpenCode plugin for v2 pattern-first planning, simulation, preview, and safe n8n workflow apply.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "examples",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:vitest": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "package:check": "node scripts/check-package-files.mjs",
    "check": "npm run typecheck && npm run test && npm run build && npm run package:check"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.15.13",
    "@opencode-ai/sdk": "1.15.13",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "n8n",
    "workflow",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drew1811266/OCN8N.git"
  },
  "bugs": {
    "url": "https://github.com/Drew1811266/OCN8N/issues"
  },
  "homepage": "https://github.com/Drew1811266/OCN8N#readme",
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
